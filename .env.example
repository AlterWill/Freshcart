# Local Development Database Configuration (PostgreSQL)
# Uncomment and fill these for local development
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=smartmart
# DB_PORT=5432

# Production Database Configuration (Neon Serverless PostgreSQL)
# Use ONE of these for production deployment
# POSTGRES_URL=postgresql://user:password@region.neon.tech/dbname (Vercel standard)
# DATABASE_URL=postgresql://user:password@region.neon.tech/dbname (Generic standard)

# Server Configuration
# PORT=5000
# NODE_ENV=development
# CLIENT_URL=http://localhost:5173
