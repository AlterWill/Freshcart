{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "env": {
    "POSTGRES_URL": "@POSTGRES_URL",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
